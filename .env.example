# =============================================================================
# Percurso — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Environment: development | production | test
ENVIRONMENT=development

# Long random string used for signing JWT tokens and other cryptographic operations.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change-me-generate-a-long-random-string

# JWT access token expiry in minutes (default: 30)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# JWT refresh token expiry in days (default: 30)
REFRESH_TOKEN_EXPIRE_DAYS=30

# Allowed origins for CORS (comma-separated). Example: http://localhost:5173,https://percurso.app
ALLOWED_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# Database (PostgreSQL 16 with PostGIS)
# -----------------------------------------------------------------------------

# Full PostgreSQL connection string.
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://percurso:percurso_password@localhost:5432/percurso_db

# Synchronous URL used by Alembic migrations only.
DATABASE_SYNC_URL=postgresql+psycopg2://percurso:percurso_password@localhost:5432/percurso_db

# PostgreSQL credentials (used by Docker Compose to initialise the container)
POSTGRES_USER=percurso
POSTGRES_PASSWORD=percurso_password
POSTGRES_DB=percurso_db

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

# Redis connection string.
REDIS_URL=redis://localhost:6379/0

# Redis database index for Celery broker (keep separate from main cache)
CELERY_REDIS_DB=1
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Wikipedia cache TTL in seconds (default: 7 days)
WIKIPEDIA_CACHE_TTL=604800

# -----------------------------------------------------------------------------
# Cloudflare R2 (object storage for user-uploaded images)
# -----------------------------------------------------------------------------
# Create an R2 bucket and an API token at: https://dash.cloudflare.com/?to=/:account/r2
#
# R2 is S3-compatible. The endpoint format is:
# https://<ACCOUNT_ID>.r2.cloudflarestorage.com

R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=percurso-media

# Public URL for the R2 bucket (e.g. https://media.percurso.app or the default R2 public URL)
# If using R2's built-in public access: https://pub-<hash>.r2.dev
R2_PUBLIC_URL=https://your-r2-public-url

# -----------------------------------------------------------------------------
# Nominatim / OpenStreetMap
# -----------------------------------------------------------------------------

# Nominatim API base URL. Use the public instance or self-host for production.
# Public instance has usage limits — see https://operations.osmfoundation.org/policies/nominatim/
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# Overpass API base URL for polygon retrieval
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# Contact email for Nominatim User-Agent (required by OSM policy)
OSM_USER_AGENT_EMAIL=your-email@example.com

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------

# Requests per minute for standard endpoints
RATE_LIMIT_DEFAULT=60

# Requests per minute for authentication endpoints (stricter)
RATE_LIMIT_AUTH=10

# -----------------------------------------------------------------------------
# Frontend (Vite build-time variables — must be prefixed with VITE_)
# -----------------------------------------------------------------------------

# Backend API base URL as seen from the browser
VITE_API_BASE_URL=http://localhost:8000

# MapLibre tile style URLs (free options: OpenFreeMap, MapTiler free tier, etc.)
VITE_MAP_STYLE_LIGHT=https://tiles.openfreemap.org/styles/liberty
VITE_MAP_STYLE_DARK=https://tiles.openfreemap.org/styles/dark
VITE_MAP_STYLE_MINIMAL=https://tiles.openfreemap.org/styles/positron

# -----------------------------------------------------------------------------
# Docker Compose internal networking (do not change unless you know what you're doing)
# -----------------------------------------------------------------------------

# Internal service URLs used between containers
INTERNAL_DATABASE_URL=postgresql+asyncpg://percurso:percurso_password@postgres:5432/percurso_db
INTERNAL_DATABASE_SYNC_URL=postgresql+psycopg2://percurso:percurso_password@postgres:5432/percurso_db
INTERNAL_REDIS_URL=redis://redis:6379/0
INTERNAL_CELERY_BROKER_URL=redis://redis:6379/1
INTERNAL_CELERY_RESULT_BACKEND=redis://redis:6379/2
